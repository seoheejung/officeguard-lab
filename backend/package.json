{
  "name": "@officeguard-lab/backend",
  "version": "1.0.0",
  "private": true,
  "description": "OfficeGuard Lab backend server",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../infra/.env --import tsx src/index.ts",
    "build": "tsc",
    "start": "node --env-file=../infra/.env dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.34.3",
  "dependencies": {
    "express": "^5.2.1",
    "kafkajs": "2.2.4",
    "pg": "^8.22.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}